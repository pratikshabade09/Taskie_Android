<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_voice_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice Assistant"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Hint label -->
    <TextView
        android:id="@+id/tv_usage_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text='Try: "Call John tomorrow at 6 PM\"'
        android:textColor="@color/text_hint"
        android:textSize="13sp"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_voice_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Animated wave ring (behind FAB) -->
    <View
        android:id="@+id/view_wave"
        android:layout_width="@dimen/wave_size"
        android:layout_height="@dimen/wave_size"
        android:background="@drawable/bg_wave_ring"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="@id/fab_mic"
        app:layout_constraintBottom_toBottomOf="@id/fab_mic"
        app:layout_constraintStart_toStartOf="@id/fab_mic"
        app:layout_constraintEnd_toEndOf="@id/fab_mic"/>

    <!-- Microphone FAB (centred in upper portion) -->

    <!-- Status text -->

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_mic"
        android:layout_width="73dp"
        android:layout_height="82dp"
        android:contentDescription="Start listening"
        android:src="@drawable/ic_mic"
        app:backgroundTint="@color/accent"
        app:elevation="8dp"
        app:fabCustomSize="@dimen/mic_fab_size"
        app:layout_constraintBottom_toTopOf="@id/tv_voice_status"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_usage_hint"
        app:layout_constraintVertical_bias="0.502"
        app:maxImageSize="32dp"
        app:tint="@color/colorOnPrimary" />

    <TextView
        android:id="@+id/tv_voice_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/voice_idle"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/tv_transcript"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Live transcript -->
    <TextView
        android:id="@+id/tv_transcript"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/accent"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="12dp"
        android:minHeight="48dp"
        app:layout_constraintBottom_toTopOf="@id/card_parsed_task"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Parsed task card (shown after recognition) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_parsed_task"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginEnd="@dimen/screen_padding"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/bg_secondary"
        app:cardCornerRadius="16dp"
        app:strokeColor="@color/accent"
        app:strokeWidth="1dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/btn_confirm_task"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Parsed task"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_parsed_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.5"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Confirm button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm_task"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="24dp"
        android:text="Add Task"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="@color/accent"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_cancel_task"/>

    <!-- Cancel button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_cancel_task"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="@dimen/screen_padding"
        android:layout_marginBottom="24dp"
        android:text="Cancel"
        android:textSize="15sp"
        android:visibility="gone"
        app:backgroundTint="@color/bg_secondary"
        app:strokeColor="@color/border"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_confirm_task"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
